TINYFISH_API_KEY=your_key_here
ANTHROPIC_API_KEY=your_key_here

# Supabase — use these names for GroundWire Python (shared_memory.py).
# Same values as Project URL + anon key in Supabase → Settings → API.
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Optional: Next.js / other frontends (shared_memory also reads these as fallbacks).
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_supabase_anon_key_here
